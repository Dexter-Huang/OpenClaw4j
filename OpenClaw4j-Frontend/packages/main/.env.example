# Web server URL
WEB_SERVER="http://127.0.0.1:8080"

# Use WEB_SERVER directly for legacy admin compatible APIs.
# Set false to use the local dev proxy at /api on port 8000.
LEGACY_API_DIRECT=true

# Backend type, e.g., java, python
BACK_END="java"

# Default username for application login
DEFAULT_USERNAME=saa

# Default password for application login
DEFAULT_PASSWORD=123456
